{
  "include": [
    "app/**/*",
    ".react-router/types/**/*"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "@retcon/common": ["./app/index.ts"],
      "@retcon/common/db": ["./app/db/index.ts"],
      "@retcon/common/db/queries": ["./app/db/queries.ts"],
      "@retcon/common/lib": ["./app/lib/index.ts"],
      "@retcon/common/lib/parseFilename": ["./app/lib/parseFilename.ts"],
      "@retcon/common/lib/comicInfoBuilder": ["./app/lib/comicInfoBuilder.ts"],
      "@retcon/common/lib/writeComicInfo": ["./app/lib/writeComicInfo.ts"],
      "@retcon/common/constants": ["./app/constants.ts"],
      "@retcon/common/metadata/providers": ["./app/metadata/providers/index.ts"]
    },
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  }
}
