# Environment variables for comic-scanner
# Copy this file to .env and modify as needed

# Database Configuration
DATABASE_URL=postgresql://comic_user:comic_password@localhost:5432/comic_scanner
POSTGRES_DB=comic_scanner
POSTGRES_USER=comic_user
POSTGRES_PASSWORD=comic_password

# Application Configuration
SCAN_DIRECTORY=/path/to/your/comics
BATCH_SIZE=50
MAX_CONCURRENT_PROCESSES=4

COVERS_DIRECTORY=/path/to/store/covers

# Logging
LOG_LEVEL=info

# Security - REQUIRED for session management
# Generate a secure random string (32+ characters recommended)
# Example: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
COOKIE_SECRET=your_cookie_secret_here

# Metadata Providers
# ComicVine API key for metadata search
# Get your API key from: https://comicvine.gamespot.com/api/
COMICVINE_API_KEY=your_comicvine_api_key_here
