{
  "name": "comic-scanner",
  "version": "1.0.0",
  "description": "A TypeScript application that scans directories for comic book files (CBZ/CBR), extracts metadata, and stores it in PostgreSQL",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "scan": "node --env-file=.env --import tsx app/scanner/index.ts",
    "typecheck": "react-router typegen && tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env --import tsx app/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [
    "comics",
    "metadata",
    "scanner",
    "cbz",
    "cbr",
    "typescript",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@react-router/dev": "^7.9.2",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^20.0.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/sharp": "^0.31.1",
    "drizzle-kit": "^0.24.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.6.0",
    "typescript": "^5.0.0",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "dependencies": {
    "@react-router/node": "^7.9.2",
    "@react-router/serve": "^7.9.2",
    "chalk": "^4.1.2",
    "drizzle-orm": "^0.33.0",
    "fast-xml-parser": "^4.3.0",
    "isbot": "^5",
    "node-stream-zip": "^1.15.0",
    "postgres": "^3.4.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router": "^7.9.2",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
