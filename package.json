{
  "name": "retcon",
  "version": "1.0.0",
  "description": "A comic book collection manager that scans directories for comic files (CBZ/CBR), extracts metadata, and provides a web interface for browsing your collection",
  "type": "module",
  "scripts": {
    "dev": "tsx app/scripts/dev.ts",
    "build": "react-router build",
    "start": "tsx app/scripts/start.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx app/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "scan": "tsx app/scanner/index.ts",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint ."
  },
  "keywords": [
    "comics",
    "metadata",
    "scanner",
    "cbz",
    "cbr",
    "typescript",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-router/node": "^7.9.2",
    "@react-router/serve": "^7.9.6",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "fast-xml-parser": "^4.3.0",
    "isbot": "^5",
    "lru-cache": "^11.2.5",
    "node-stream-zip": "^1.15.0",
    "postgres": "^3.4.0",
    "ramda": "^0.32.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.66.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.9.2",
    "react-swipeable": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "remix-auth": "^4.2.0",
    "remix-auth-form": "^3.0.0",
    "sharp": "^0.34.5",
    "sqids": "^0.3.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@react-router/dev": "^7.9.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^25.2.0",
    "@types/ramda": "^0.31.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/sharp": "^0.31.1",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.6.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
